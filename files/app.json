{
  "expo": {
    "name": "InvoiceGenerator",
    "slug": "InvoiceGenerator",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/invoice_logo.jpeg",
    "scheme": "invoicegenerator",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/invoice_logo.jpeg",
        "backgroundColor": "#ffffff"
      },
      "package": "com.honeyjadav.InvoiceGenerator"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": true
          },
          "ios": {
            "newArchEnabled": true
          }
        }
      ],
      "expo-sqlite",
      "expo-font",
      "expo-image",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6a4cfa0a-7121-4d66-851a-58d72af22633"
      }
    }
  }
}
